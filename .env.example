# 复制为 .env.local 后填写；.env.local 已被 git 忽略。
PORT=4173

# DeepL（可选）
DEEPL_AUTH_KEY=
# 留空时根据密钥是否以 :fx 结尾自动选择 Free / Pro 地址。
DEEPL_SERVER_URL=

# OpenAI-compatible Chat Completions（可选，不使用 OPENAI_API_KEY）
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=
OPENAI_COMPAT_ALLOW_NO_AUTH=false

# 本地服务设置
TRANSLATION_ALLOW_CLIENT_CONFIG=true
TRANSLATION_TIMEOUT_MS=15000
